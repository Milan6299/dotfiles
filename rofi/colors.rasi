* {
    background: #26211c;
    foreground: #d8c8a8;
    background-alt: #302822;
    accent: #c98c5a;
    accent-alt: #6d7d8c;
    border: #54483e;
    warning: #c0a36e;
    error: #b85c4d;
    success: #8b9560;
    info: #78907a;
    selected: #3a312a;
    gray1: #26211c;
    gray2: #302822;
    gray3: #3a312a;
    gray4: #54483e;
    gray5: #6a5c4f;
    gray6: #817264;
    gray7: #9a8b7d;
    background-dim: #211c18;
    foreground-dim: #b7a78d;
    background-highlight: #3a312a;
}
