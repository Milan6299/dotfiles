# Window Rules

# Browser on workspace 2
assign [app_id="firefox"] workspace 2

# Krita
assign [class="krita"] workspace 3

# Blender
assign [app_id="blender"] workspace 3

# Dota
assign [class="dota2"] workspace 5

# Floating utility windows

for_window [app_id="quickedit"] floating enable, resize set 1400 900
for_window [app_id="cheatsheet"] floating enable, resize set 1400 900
for_window [app_id="nmtui-go"] floating enable, resize set 1000 800
for_window [app_id="file_chooser"] floating enable, resize set 1200 800

# Firefox dialogs
# for_window [app_id="firefox" title=".*Save.*"] floating enable
# for_window [app_id="firefox" title=".*wants to.*"] floating enable

# Sign
for_window [class="Sign"] floating enable
